{
  "expo": {
    "name": "MobilePwn Lab",
    "slug": "mobilepwn-lab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marcosecurity.mobilepwnlab"
    },
    "android": {
      "package": "com.marcosecurity.mobilepwnlab",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "allowBackup": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withDebuggable"
    ],
    "extra": {
      "eas": {
        "projectId": "ebe5a8b2-b7f8-4088-9be4-b591df7e258b"
      }
    }
  }
}